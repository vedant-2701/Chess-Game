# ============================================================
# chess-server environment configuration
# Copy this file to .env and fill in real values.
# Never commit .env to version control.
# ============================================================

# Server
SERVER_PORT=8080

# Logging — valid values: debug, info, warn, error
LOG_LEVEL=debug

# Database
# Matches the postgres service defined in docker-compose.yml.
# For the migrate CLI, use this URL directly.
# For the Go app, this is passed to pgxpool.New().
DATABASE_URL=postgres://chess:chess@localhost:5432/chess?sslmode=disable

# JWT signing secret — CHANGE THIS before running.
# Generate a secure value with: openssl rand -hex 32
JWT_SECRET=change-this-to-a-random-secret-minimum-32-characters

# Redis (Phase 2 — routing directory: ownership + liveness keys, not an
# EventBus. See DECISIONS_LOG_PHASE_2.md ADR-021/ADR-023.)
# Matches the redis service defined in docker-compose.yml. Host:port form,
# not a redis:// URL — passed directly to go-redis's Options.Addr.
REDIS_ADDR=localhost:6379

# INSTANCE_ID — a unique identifier for this replica, required in any
# multi-instance (Phase 2) deployment. Used as the value stored under the
# game:{gameID} ownership key and as the key for instance_alive:{instanceID}.
# No safe default across replicas: two replicas silently sharing an ID would
# corrupt routing. Set explicitly per replica, e.g. server-1, server-2 — for
# single-instance local dev, any unique value works.
INSTANCE_ID=instance-1
