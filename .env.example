# ============================================================
# chess-server environment configuration
# Copy this file to .env and fill in real values.
# Never commit .env to version control.
# ============================================================

# Server
SERVER_PORT=8080

# Logging — valid values: debug, info, warn, error
LOG_LEVEL=debug

# Database
# Matches the postgres service defined in docker-compose.yml.
# For the migrate CLI, use this URL directly.
# For the Go app, this is passed to pgxpool.New().
DATABASE_URL=postgres://chess:chess@localhost:5432/chess?sslmode=disable

# JWT signing secret — CHANGE THIS before running.
# Generate a secure value with: openssl rand -hex 32
JWT_SECRET=change-this-to-a-random-secret-minimum-32-characters
